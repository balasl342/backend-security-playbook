# Copy to .env and adjust for local development.
# All keys mirror configs/config.yaml, uppercased, dot-nesting replaced with
# underscores, and prefixed with APP_.

APP_ENV=development

APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=8080

APP_DATABASE_HOST=localhost
APP_DATABASE_PORT=5432
APP_DATABASE_USER=playground
APP_DATABASE_PASSWORD=playground
APP_DATABASE_NAME=playground
APP_DATABASE_SSL_MODE=disable

APP_REDIS_ENABLED=false
APP_REDIS_ADDR=localhost:6379

APP_LOG_LEVEL=info
APP_LOG_FORMAT=json

# crypto.mode: plaintext (Mode A, relies on DB TDE) | envelope (Mode B)
APP_CRYPTO_MODE=envelope
# crypto.kms_provider: local | aws
APP_CRYPTO_KMS_PROVIDER=local
APP_CRYPTO_LOCAL_MASTER_KEY_PATH=configs/dev-master.key
APP_CRYPTO_AWS_KEY_ID=
APP_CRYPTO_AWS_REGION=us-east-1

# secrets.provider: env | file | aws_secrets_manager | vault | azure_key_vault
APP_SECRETS_PROVIDER=env
APP_SECRETS_FILE_PATH=configs/secrets.local.yaml

APP_OBSERVABILITY_METRICS_ENABLED=true
APP_OBSERVABILITY_TRACING_ENABLED=false
